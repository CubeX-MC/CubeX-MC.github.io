---
import { people } from '../data/members';

const variantStyles = {
  core: 'border-l-2 border-l-cubex-red/40',
  contributor: 'border-l-2 border-l-white/10',
  retired: 'border-l-2 border-l-white/6',
};
---

<section id="members" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-cubex-red text-sm font-semibold tracking-widest uppercase mb-3">People</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">CubeX 的人们</h2>
      <p class="text-white/45 max-w-2xl mx-auto">
        CubeX 是以 HyperCube 为核心的泛贡献者社区。HyperCube 维护着插件生态和组织资产，围绕它的是各服务器的运营者和曾经的贡献者。
      </p>
    </div>

    {people.map((section) => (
      <div class="mb-16 last:mb-0">
        <!-- Sub-section header -->
        <div class="mb-8 flex items-center gap-3">
          <div class={`w-3 h-3 ${section.variant === 'core' ? 'bg-cubex-red' : 'bg-white/20'}`}></div>
          <div>
            <h3 class="text-lg font-bold">{section.title}</h3>
            <p class="text-white/40 text-sm">{section.description}</p>
          </div>
        </div>

        <!-- Member cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {section.members.map((member) => (
            <div class={`glass-card p-4 ${variantStyles[section.variant]}`}>
              <div class="flex items-start justify-between mb-2">
                <div>
                  <div class="flex items-baseline gap-2">
                    <h4 class="text-sm font-bold">{member.name}</h4>
                    {member.aliases && member.aliases.length > 0 && (
                      <span class="text-white/20 text-xs">
                        {member.aliases.join(' / ')}
                      </span>
                    )}
                  </div>
                  <p class="text-cubex-red/70 text-xs mt-0.5">{member.role}</p>
                </div>
                {member.badge && (
                  <span class="tag-pill bg-cubex-red/15 text-cubex-red text-[0.65rem]">
                    {member.badge}
                  </span>
                )}
              </div>

              {member.description && member.description !== `HyperCube 核心成员。` && member.description !== `HyperCube 核心成员` && (
                <p class="text-white/40 text-xs leading-relaxed mb-3">{member.description}</p>
              )}

              {member.links && member.links.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-2 border-t border-white/5">
                  {member.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-[0.65rem] text-white/30 hover:text-white/55 transition-colors flex items-center gap-0.5"
                    >
                      {link.label}
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
