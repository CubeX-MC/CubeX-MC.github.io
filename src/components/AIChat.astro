---

<section id="chat" class="py-24 px-6">
  <div class="mx-auto max-w-3xl">
    <div class="text-center mb-10">
      <p class="text-cubex-red text-sm font-semibold tracking-widest uppercase mb-3">AI Chat Room</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">匿名聊天室</h2>
      <p class="text-white/45 max-w-2xl mx-auto">
        CubeX AI 常驻社区，随时陪你聊 Minecraft！
        <br class="hidden md:inline" />
        <span class="text-white/25 text-xs">消息由 AI 生成，仅供参考娱乐</span>
      </p>
    </div>

    <div class="glass-card p-4 md:p-6 overflow-hidden">
      <!-- Messages area -->
      <div id="chat-messages" class="space-y-4 max-h-[600px] overflow-y-auto pr-2 mb-4">
        <p class="text-white/35 text-center py-12">加载中...</p>
      </div>

      <div class="gradient-line mb-4"></div>

      <!-- Input area -->
      <div class="flex items-center gap-2">
        <input
          id="chat-nickname"
          type="text"
          maxlength="12"
          placeholder="匿名"
          class="w-16 md:w-20 px-2 py-2.5 rounded-full border border-white/10 bg-white/5 text-white/60 text-sm text-center placeholder-white/25 focus:outline-none focus:border-white/20 transition-colors shrink-0"
        />
        <input
          id="chat-input"
          type="text"
          maxlength="500"
          placeholder="输入消息..."
          class="flex-1 px-4 py-2.5 rounded-full border border-white/10 bg-white/5 text-white/80 text-sm placeholder-white/25 focus:outline-none focus:border-white/20 transition-colors"
        />
        <button
          id="chat-send"
          class="px-5 py-2.5 rounded-full bg-cubex-red/80 text-white text-sm font-medium hover:bg-cubex-red transition-colors disabled:opacity-30 disabled:cursor-not-allowed shrink-0"
        >
          发送
        </button>
      </div>
      <p class="text-white/20 text-xs text-center mt-3" id="chat-status">
        连接中...
      </p>
    </div>
  </div>
</section>

<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
  import {
    getFirestore,
    collection,
    addDoc,
    query,
    orderBy,
    limit,
    onSnapshot,
    serverTimestamp,
  } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-firestore.js';

  const cfg = {JSON.stringify(firebaseConfig)};

  const app = initializeApp(cfg);
  const db = getFirestore(app);

  const container = document.getElementById('chat-messages');
  const input = document.getElementById('chat-input');
  const nicknameInput = document.getElementById('chat-nickname');
  const sendBtn = document.getElementById('chat-send');
  const status = document.getElementById('chat-status');

  let lastSendTime = 0;
  const SEND_COOLDOWN = 10_000; // 10 seconds

  function esc(s) {
    return String(s).replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function formatTime(ts) {
    if (!ts) return '';
    const d = ts.toDate ? ts.toDate() : new Date(ts);
    return d.toLocaleString('zh-CN', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function renderMessages(msgs) {
    if (!msgs.length) {
      container.innerHTML = '<p class="text-white/35 text-center py-12">还没有消息，来发第一条吧！</p>';
      return;
    }
    let html = '';
    for (const m of msgs) {
      const isUser = m.author === 'user';
      const avatarClass = m.author === 'ai'
        ? 'bg-cubex-red/20 text-cubex-red'
        : 'bg-white/10 text-white/50';
      const bubbleClass = m.author === 'ai'
        ? 'bg-white/8 rounded-tl-none'
        : 'bg-cubex-red/15 rounded-tr-none';
      html +=
        '<div class="flex gap-3' + (isUser ? ' flex-row-reverse' : '') + '">' +
          '<div class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ' + avatarClass + '">' +
            (m.author === 'ai' ? 'AI' : (m.name || '?')[0].toUpperCase()) +
          '</div>' +
          '<div class="max-w-[75%]' + (isUser ? ' text-right' : '') + '">' +
            '<div class="text-xs text-white/35 mb-1">' +
              esc(m.name || '?') +
              '<span class="mx-1.5 opacity-30">&middot;</span>' +
              '<time datetime="' + (m.timestamp || '') + '" class="opacity-50">' + formatTime(m.timestamp) + '</time>' +
            '</div>' +
            '<div class="inline-block px-3 py-2 rounded-2xl text-sm leading-relaxed ' + bubbleClass + '">' +
              esc(m.content) +
            '</div>' +
          '</div>' +
        '</div>';
    }
    container.innerHTML = html;
    container.scrollTop = container.scrollHeight;
  }

  // Real-time listener
  const q = query(collection(db, 'chat-messages'), orderBy('timestamp', 'asc'), limit(200));
  onSnapshot(q, (snap) => {
    const msgs = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
    renderMessages(msgs);
    status.textContent = '实时连接中';
    status.style.color = '';
  }, (err) => {
    console.error('Firestore error:', err);
    status.textContent = '连接失败，请刷新页面';
    status.style.color = '#f87171';
  });

  // Send message
  async function sendMessage() {
    const content = input.value.trim();
    if (!content) return;

    const now = Date.now();
    if (now - lastSendTime < SEND_COOLDOWN) {
      input.placeholder = '发送太快了，稍等一下...';
      setTimeout(() => { input.placeholder = '输入消息...'; }, 2000);
      return;
    }

    const nickname = nicknameInput.value.trim() || '匿名玩家';
    sendBtn.disabled = true;
    input.disabled = true;
    lastSendTime = now;

    try {
      await addDoc(collection(db, 'chat-messages'), {
        author: 'user',
        name: nickname,
        content,
        timestamp: serverTimestamp(),
      });
      input.value = '';
    } catch (err) {
      console.error('Send failed:', err);
      status.textContent = '发送失败，请重试';
      status.style.color = '#f87171';
      setTimeout(() => {
        status.textContent = '实时连接中';
        status.style.color = '';
      }, 3000);
    } finally {
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage();
  });
</script>
