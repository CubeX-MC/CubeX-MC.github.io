---
import { plugins } from '../data/plugins';
---

<section id="plugins" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-cubex-red text-sm font-semibold tracking-widest uppercase mb-3">Plugins</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">我们的插件</h2>
      <p class="text-white/45 max-w-2xl mx-auto">
        我们开发和维护着自己的插件生态，从经济平衡到铁路管理，从权限宝石化到方块替换。
      </p>
    </div>

    <!-- Plugin cards -->
    <div class="space-y-4">
      {plugins.map((plugin) => (
        <div class="glass-card p-5 md:p-7">
          <div class="flex flex-col md:flex-row gap-5">
            <!-- Icon -->
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-cubex-red/10 flex items-center justify-center text-xl">
                {plugin.icon}
              </div>
            </div>

            <div class="flex-1">
              <div class="flex flex-col md:flex-row md:items-center gap-2 mb-2">
                <h3 class="text-lg font-bold">{plugin.name}</h3>
                <div class="flex gap-1.5">
                  {plugin.platforms.map((p) => (
                    <span class="tag-pill bg-cubex-blue/10 text-cubex-blue">{p}</span>
                  ))}
                </div>
              </div>

              <p class="text-white/50 text-sm leading-relaxed mb-3">
                {plugin.description}
              </p>

              <!-- Features -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {plugin.features.map((f) => (
                  <span class="tag-pill bg-white/[0.04] text-white/45">
                    {f}
                  </span>
                ))}
              </div>

              <!-- Links -->
              {plugin.links && plugin.links.length > 0 && (
                <div class="flex gap-4">
                  {plugin.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-sm text-cubex-red hover:text-cubex-accent transition-colors flex items-center gap-1"
                    >
                      {link.label}
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
