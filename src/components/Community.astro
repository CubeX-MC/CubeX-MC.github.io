---
import { people } from '../data/members';

const coreMembers = people.find((section) => section.variant === 'core')?.members ?? [];
const contributors = people.find((section) => section.variant === 'retired')?.members ?? [];
const allPeople = [...coreMembers, ...contributors];

const coreLinks = [
  { label: 'HyperCube Discord', desc: '核心组织交流', url: 'https://discord.gg/7tJeSZPZgv', tone: 'bg-[#5865F2]/12 text-[#5865F2]' },
  { label: 'GitHub', desc: 'CubeX-MC 组织', url: 'https://github.com/CubeX-MC', tone: 'bg-white/8 text-white/70' },
  { label: 'Modrinth', desc: 'CubeX 组织页面', url: 'https://modrinth.com/organization/cubexmc', tone: 'bg-cubex-green/12 text-cubex-green' },
  { label: 'Discussions', desc: 'GitHub 讨论区', url: 'https://github.com/CubeX-MC/CubeX-MC.github.io/discussions', tone: 'bg-cubex-red/10 text-cubex-red' },
];

const qqGroups = [
  { name: 'CubeX 服务器群', value: '470579814', href: 'https://jq.qq.com/?_wv=1027&k=g38XNewm', note: '主入口' },
  { name: 'CubeX ELite 内测群', value: '835031357', note: 'RPG 内测' },
  { name: 'CubeX Wonderful 群', value: '1042692728', note: '社区实验服' },
  { name: 'CubeX 开服群', value: '614479400', note: '运营讨论' },
  { name: 'CubeX 玩家代表群', value: '261026870', note: '玩家反馈' },
  { name: 'CubeX 社区群', value: '296590378', note: '一周目 Commune 社区' },
  { name: 'WolfX 社区群', value: '801731569', note: '起源社区' },
  { name: '云湖边社区群', value: '766910766', note: '友邻社区' },
  { name: 'Eutopia 社区', value: '894099870', note: '友邻社区' },
  { name: 'CubeX 吵架群', value: '713832786', note: '慎入' },
];

const platformLinks = [
  { label: 'Telegram', desc: 'CubeX 服务器频道', url: 'https://t.me/cbxmc' },
  { label: 'CubeX Discord', desc: '服务器社区', url: 'https://discord.gg/QWKcSZFert' },
  { label: 'Bilibili', desc: 'CubeX 官方', url: 'https://space.bilibili.com/3546921981446556' },
];

const highlightedMembers = coreMembers.filter((member) => ['angushushu', 'Adlambxd', 'addxiaoyi', 'Steve3184', 'FZAoao', 'LCDJ'].includes(member.name));
---

<section id="community" class="px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.72fr] lg:items-end">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-cubex-red">Community</p>
        <h1 class="text-3xl font-bold md:text-5xl">社区网络</h1>
        <p class="mt-5 max-w-3xl text-sm leading-relaxed text-white/50 md:text-base">
          CubeX 不只是一个服务器名，而是一组服务器、项目、成员、历史和聊天入口交织成的网络。这里合并了社区入口和成员索引，方便新玩家找组织，也方便老玩家回来看谁还在做事。
        </p>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div class="border border-white/7 bg-white/[0.025] p-4">
          <p class="text-xs uppercase tracking-wider text-white/25">Core</p>
          <p class="mt-2 text-3xl font-bold text-white">{coreMembers.length}</p>
          <p class="mt-1 text-xs text-white/35">HyperCube 成员</p>
        </div>
        <div class="border border-white/7 bg-white/[0.025] p-4">
          <p class="text-xs uppercase tracking-wider text-white/25">People</p>
          <p class="mt-2 text-3xl font-bold text-white">{allPeople.length}</p>
          <p class="mt-1 text-xs text-white/35">收录成员</p>
        </div>
        <div class="border border-white/7 bg-white/[0.025] p-4">
          <p class="text-xs uppercase tracking-wider text-white/25">Groups</p>
          <p class="mt-2 text-3xl font-bold text-white">{qqGroups.length}</p>
          <p class="mt-1 text-xs text-white/35">QQ群入口</p>
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="glass-card p-5 md:p-6">
        <p class="text-xs uppercase tracking-wider text-white/30">Network</p>
        <h2 class="mt-1 text-xl font-bold">核心入口</h2>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {coreLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener" class="flex items-center gap-3 border border-white/7 bg-white/[0.025] p-4 transition-colors hover:border-cubex-red/30 hover:bg-white/[0.045]">
              <span class={`flex h-9 w-9 items-center justify-center text-xs font-bold ${link.tone}`}>{link.label.slice(0, 2)}</span>
              <span>
                <span class="block text-sm font-semibold text-white/80">{link.label}</span>
                <span class="block text-xs text-white/35">{link.desc}</span>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="glass-card p-5 md:p-6">
        <p class="text-xs uppercase tracking-wider text-white/30">People</p>
        <h2 class="mt-1 text-xl font-bold">活跃角色</h2>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {highlightedMembers.map((member) => (
            <div class="border border-white/7 bg-white/[0.025] p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="font-semibold text-white">{member.name}</h3>
                  <p class="mt-1 text-xs text-cubex-red/75">{member.role}</p>
                </div>
                {member.badge && <span class="tag-pill bg-cubex-red/15 text-cubex-red">{member.badge}</span>}
              </div>
              <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-white/40">{member.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <section>
        <div class="mb-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-cubex-red">Chat</p>
          <h2 class="mt-1 text-2xl font-bold">聊天与平台</h2>
        </div>

        <div class="grid gap-3">
          {qqGroups.map((group) => (
            <div class="glass-card flex items-center justify-between gap-4 p-4">
              <div>
                <h3 class="text-sm font-semibold text-white/85">{group.name}</h3>
                <p class="mt-1 text-xs text-white/35">{group.value} · {group.note}</p>
              </div>
              {group.href ? (
                <a href={group.href} target="_blank" rel="noopener" class="text-xs text-cubex-red hover:text-cubex-accent">加入</a>
              ) : (
                <span class="font-mono text-xs text-white/25">{group.value}</span>
              )}
            </div>
          ))}
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {platformLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener" class="glass-card block p-4 hover:border-cubex-red/25">
              <p class="text-sm font-semibold text-white/80">{link.label}</p>
              <p class="mt-1 text-xs text-white/35">{link.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="mb-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-cubex-red">Directory</p>
          <h2 class="mt-1 text-2xl font-bold">成员与贡献者</h2>
        </div>

        <div class="space-y-8">
          {people.map((section) => (
            <div>
              <div class="mb-3 flex items-center justify-between gap-4">
                <div>
                  <h3 class="font-bold text-white">{section.title}</h3>
                  <p class="mt-1 text-sm text-white/35">{section.description}</p>
                </div>
                <span class="tag-pill bg-white/[0.04] text-white/45">{section.members.length} 人</span>
              </div>
              <div class="grid gap-3 md:grid-cols-2">
                {section.members.map((member) => (
                  <article class="border border-white/7 bg-white/[0.025] p-4">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <div class="flex flex-wrap items-baseline gap-2">
                          <h4 class="font-semibold text-white/85">{member.name}</h4>
                          {member.aliases && member.aliases.length > 0 && (
                            <span class="text-xs text-white/25">{member.aliases.join(' / ')}</span>
                          )}
                        </div>
                        <p class="mt-1 text-xs text-cubex-red/70">{member.role}</p>
                      </div>
                      {member.badge && <span class="tag-pill bg-cubex-red/15 text-cubex-red">{member.badge}</span>}
                    </div>

                    {member.description && member.description !== 'HyperCube 核心成员。' && member.description !== 'HyperCube 核心成员' && (
                      <p class="mt-3 text-xs leading-relaxed text-white/40">{member.description}</p>
                    )}

                    {member.links && member.links.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-3 border-t border-white/5 pt-3">
                        {member.links.map((link) => (
                          <a href={link.url} target="_blank" rel="noopener" class="text-xs text-cubex-red transition-colors hover:text-cubex-accent">
                            {link.label}
                          </a>
                        ))}
                      </div>
                    )}
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</section>
