<section id="community" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-cubex-red text-sm font-semibold tracking-widest uppercase mb-3">Community</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">泛 CubeX 网络</h2>
      <p class="text-white/45 max-w-2xl mx-auto">
        从核心的 HyperCube 到各服务器社区，从 QQ 群到 Discord，这里是泛 CubeX 的完整网络。
      </p>
    </div>

    <!-- Network links organized by category -->
    <div class="space-y-12 mb-16">
      <!-- Core: HyperCube -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-2 h-2 bg-cubex-red"></div>
          <h3 class="text-sm font-bold text-white/70 uppercase tracking-wider">HyperCube 核心</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="https://discord.gg/7tJeSZPZgv" target="_blank" rel="noopener" class="glass-card p-4 flex items-center gap-3 group cursor-pointer">
