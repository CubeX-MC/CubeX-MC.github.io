---
import targets from '../data/serverRecordTargets.json';
import recordsData from '../data/serverRecords.json';

const formatDateTime = (value: string | null) => {
  if (!value) return '等待采样';
  return new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Shanghai',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(new Date(value));
};

const updatedAt = recordsData.updatedAt
  ? formatDateTime(recordsData.updatedAt)
  : '等待第一次纪录';

const chartPalette = ['#c4713a', '#58d68d', '#6aa6ff'];
const chartTargets = targets.map((target, index) => ({
  id: target.id,
  name: target.name,
  color: chartPalette[index % chartPalette.length],
}));
---

<section id="records" class="py-20 px-6">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-cubex-red">Records</p>
        <h2 class="text-3xl font-bold md:text-4xl">人数纪录</h2>
      </div>
      <p class="text-sm text-white/35 md:text-right">
        MC百科找服玩 / mcsrvstat.us · {updatedAt}
      </p>
    </div>

    <div
      class="glass-card mb-5 p-5 md:p-6"
      data-history-chart
      data-history-src="/data/server-history.json"
      data-default-server={chartTargets[0]?.id}
    >
      <script type="application/json" data-history-series set:html={JSON.stringify(chartTargets)} />
      <div class="mb-5 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-cubex-red">HyperCube Network</p>
          <h3 class="mt-1 text-2xl font-bold text-white">在线人数历史曲线</h3>
          <p class="mt-2 text-sm text-white/40">
            MC百科找服玩 / mcsrvstat.us · GitHub Actions 同步
          </p>
        </div>
        <div class="flex flex-wrap gap-2 md:justify-end" data-server-options>
          {chartTargets.map((target, index) => (
            <button
              type="button"
              class={`tag-pill transition-colors ${index === 0 ? 'bg-cubex-red/15 text-cubex-red' : 'bg-white/[0.04] text-white/45'}`}
              data-server-option={target.id}
            >
              <span class="mr-1.5 inline-block h-2 w-2" style={`background:${target.color}`} />
              {target.name}
            </button>
          ))}
        </div>
      </div>

      <div class="relative h-72 border border-white/5 bg-white/[0.025]">
        <canvas class="h-full w-full" data-history-canvas></canvas>
        <div
          class="pointer-events-none absolute hidden border border-white/10 bg-cubex-darker/95 px-3 py-2 text-xs text-white/70 shadow-xl"
          data-history-tooltip
        ></div>
      </div>

      <div class="mt-4 h-20 border border-white/5 bg-white/[0.025]">
        <canvas class="h-full w-full cursor-ew-resize touch-none" data-history-overview></canvas>
      </div>

      <div class="mt-3 flex flex-col gap-1 text-xs text-white/40 sm:flex-row sm:items-center sm:justify-between">
        <p data-history-window>选择区间</p>
        <p data-history-meta>载入中</p>
      </div>
    </div>
  </div>
</section>

<script>
  const chartRoot = document.querySelector('[data-history-chart]');
  const canvas = chartRoot?.querySelector('[data-history-canvas]');
  const overview = chartRoot?.querySelector('[data-history-overview]');
  const tooltip = chartRoot?.querySelector('[data-history-tooltip]');
  const meta = chartRoot?.querySelector('[data-history-meta]');
  const windowLabel = chartRoot?.querySelector('[data-history-window]');
  const optionButtons = chartRoot?.querySelectorAll('[data-server-option]');
  const seriesScript = chartRoot?.querySelector('[data-history-series]');

  const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Shanghai',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  });

  let allSeries = [];
  let selectedId = chartRoot?.getAttribute('data-default-server') || '';
  let visiblePoints = [];
  let brush = { start: 0, end: 1 };
  let dragState = null;

  const setMeta = (text) => {
    if (meta) meta.textContent = text;
  };

  const setWindowLabel = (text) => {
    if (windowLabel) windowLabel.textContent = text;
  };

  const formatPointDate = (time) => dateFormatter.format(new Date(time));
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

  const getSelectedSeries = () =>
    allSeries.find((series) => series.id === selectedId) || allSeries[0] || null;

  const simplifyForCanvas = (points, width) => {
    const maxPoints = Math.max(1, Math.floor(width * 3));
    if (points.length <= maxPoints) return points;

    const step = Math.ceil(points.length / maxPoints);
    const simplified = [];
    for (let i = 0; i < points.length; i += step) {
      let peak = points[i];
      for (let j = i + 1; j < Math.min(i + step, points.length); j += 1) {
        if (points[j][1] > peak[1]) peak = points[j];
      }
      simplified.push(peak);
    }
    return simplified;
  };

  const getBrushTimes = (series) => {
    const first = series.points[0]?.[0] ?? 0;
    const last = series.points.at(-1)?.[0] ?? first;
    const span = Math.max(1, last - first);
    return [
      first + span * brush.start,
      first + span * brush.end,
    ];
  };

  const resetBrush = (series) => {
    if (!series || series.points.length < 2) {
      brush = { start: 0, end: 1 };
      return;
    }

    const first = series.points[0][0];
    const last = series.points.at(-1)[0];
    const span = Math.max(1, last - first);
    const defaultSpan = 180 * 24 * 60 * 60 * 1000;
    brush = span > defaultSpan
      ? { start: clamp(1 - defaultSpan / span, 0, 1), end: 1 }
      : { start: 0, end: 1 };
  };

  const drawChart = () => {
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const context = canvas.getContext('2d');
    if (!context) return;

    const rect = canvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const width = Math.max(1, Math.floor(rect.width));
    const height = Math.max(1, Math.floor(rect.height));

    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    context.setTransform(dpr, 0, 0, dpr, 0, 0);
    context.clearRect(0, 0, width, height);

    const series = getSelectedSeries();
    if (!series) return;

    const [rangeStart, rangeEnd] = getBrushTimes(series);
    visiblePoints = series.points.filter(([time]) => time >= rangeStart && time <= rangeEnd);

    if (visiblePoints.length === 0) {
      context.fillStyle = 'rgba(255,255,255,0.28)';
      context.font = '14px sans-serif';
      context.fillText('暂无曲线数据', 20, 34);
      setMeta('暂无数据');
      setWindowLabel('选择区间');
      return;
    }

    const padding = { left: 42, right: 16, top: 18, bottom: 30 };
    const plotWidth = width - padding.left - padding.right;
    const plotHeight = height - padding.top - padding.bottom;
    const rawMax = Math.max(1, ...visiblePoints.map(([, players]) => players));
    const maxPlayers = Math.ceil(rawMax / 10) * 10;

    const xOf = (time) => padding.left + ((time - rangeStart) / Math.max(1, rangeEnd - rangeStart)) * plotWidth;
    const yOf = (players) => padding.top + (1 - players / maxPlayers) * plotHeight;

    context.strokeStyle = 'rgba(255,255,255,0.07)';
    context.lineWidth = 1;
    context.fillStyle = 'rgba(255,255,255,0.28)';
    context.font = '11px sans-serif';
    for (let value = 0; value <= maxPlayers; value += 10) {
      const y = yOf(value);
      context.beginPath();
      context.moveTo(padding.left, y);
      context.lineTo(width - padding.right, y);
      context.stroke();
      context.fillText(String(value), 12, y + 4);
    }

    const drawPoints = simplifyForCanvas(visiblePoints, plotWidth);
    context.beginPath();
    drawPoints.forEach(([time, players], index) => {
      const x = xOf(time);
      const y = yOf(players);
      if (index === 0) context.moveTo(x, y);
      else context.lineTo(x, y);
    });
    context.strokeStyle = series.color;
    context.lineWidth = 2;
    context.stroke();

    if (drawPoints.length === 1) {
      const [time, players] = drawPoints[0];
      context.beginPath();
      context.arc(xOf(time), yOf(players), 3, 0, Math.PI * 2);
      context.fillStyle = series.color;
      context.fill();
    }

    context.fillStyle = 'rgba(255,255,255,0.35)';
    context.fillText(formatPointDate(rangeStart).slice(5), padding.left, height - 10);
    const endLabel = formatPointDate(rangeEnd).slice(5);
    context.fillText(endLabel, Math.max(padding.left, width - padding.right - 88), height - 10);

    const peak = visiblePoints.reduce((best, point) => (point[1] > best[1] ? point : best), visiblePoints[0]);
    setMeta(`${series.name} · ${visiblePoints.length.toLocaleString()} 个点 · 区间最高 ${peak[1]} 人`);
    setWindowLabel(`${formatPointDate(rangeStart)} - ${formatPointDate(rangeEnd)}`);
  };

  const drawOverview = () => {
    if (!(overview instanceof HTMLCanvasElement)) return;
    const context = overview.getContext('2d');
    if (!context) return;

    const series = getSelectedSeries();
    const rect = overview.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const width = Math.max(1, Math.floor(rect.width));
    const height = Math.max(1, Math.floor(rect.height));

    overview.width = Math.floor(width * dpr);
    overview.height = Math.floor(height * dpr);
    context.setTransform(dpr, 0, 0, dpr, 0, 0);
    context.clearRect(0, 0, width, height);
    context.fillStyle = 'rgba(255,255,255,0.025)';
    context.fillRect(0, 0, width, height);

    if (!series || series.points.length === 0) {
      context.fillStyle = 'rgba(255,255,255,0.28)';
      context.font = '12px sans-serif';
      context.fillText('暂无历史采样', 16, 28);
      return;
    }

    const padding = { left: 8, right: 8, top: 8, bottom: 10 };
    const first = series.points[0][0];
    const last = series.points.at(-1)[0];
    const span = Math.max(1, last - first);
    const rawMax = Math.max(1, ...series.points.map(([, players]) => players));
    const maxPlayers = Math.ceil(rawMax / 10) * 10;
    const plotWidth = width - padding.left - padding.right;
    const plotHeight = height - padding.top - padding.bottom;
    const xOf = (time) => padding.left + ((time - first) / span) * plotWidth;
    const yOf = (players) => padding.top + (1 - players / maxPlayers) * plotHeight;
    const overviewPoints = simplifyForCanvas(series.points, plotWidth * 2);

    context.beginPath();
    overviewPoints.forEach(([time, players], index) => {
      const x = xOf(time);
      const y = yOf(players);
      if (index === 0) context.moveTo(x, y);
      else context.lineTo(x, y);
    });
    context.strokeStyle = series.color;
    context.globalAlpha = 0.75;
    context.lineWidth = 1.5;
    context.stroke();
    context.globalAlpha = 1;

    const left = padding.left + brush.start * plotWidth;
    const right = padding.left + brush.end * plotWidth;
    context.fillStyle = 'rgba(0,0,0,0.42)';
    context.fillRect(0, 0, left, height);
    context.fillRect(right, 0, width - right, height);
    context.strokeStyle = 'rgba(255,255,255,0.55)';
    context.lineWidth = 1;
    context.strokeRect(left, 0.5, Math.max(1, right - left), height - 1);
    context.fillStyle = 'rgba(255,255,255,0.45)';
    context.fillRect(left - 1, 12, 2, height - 24);
    context.fillRect(right - 1, 12, 2, height - 24);
  };

  const drawAll = () => {
    drawChart();
    drawOverview();
  };

  const nearestPoint = (targetTime) => {
    const points = visiblePoints;
    let nearest = null;
    for (const point of points) {
      if (!nearest || Math.abs(point[0] - targetTime) < Math.abs(nearest[0] - targetTime)) {
        nearest = point;
      }
    }
    return nearest;
  };

  canvas?.addEventListener('mousemove', (event) => {
    const series = getSelectedSeries();
    if (!(canvas instanceof HTMLCanvasElement) || !(tooltip instanceof HTMLElement) || !series || visiblePoints.length === 0) return;
    const rect = canvas.getBoundingClientRect();
    const [firstTime, lastTime] = getBrushTimes(series);
    const ratio = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
    const point = nearestPoint(firstTime + ratio * (lastTime - firstTime));
    if (!point) return;

    tooltip.classList.remove('hidden');
    tooltip.innerHTML = `<p>${formatPointDate(point[0])}</p><p class="mt-1" style="color:${series.color}">${series.name} · ${point[1]} 人在线</p>`;
    tooltip.style.left = `${Math.min(rect.width - 150, Math.max(8, event.clientX - rect.left + 12))}px`;
    tooltip.style.top = `${Math.max(8, event.clientY - rect.top - 48)}px`;
  });

  canvas?.addEventListener('mouseleave', () => {
    tooltip?.classList.add('hidden');
  });

  optionButtons?.forEach((button) => {
    button.addEventListener('click', () => {
      selectedId = button.getAttribute('data-server-option') || selectedId;
      optionButtons.forEach((item) => {
        item.className = 'tag-pill bg-white/[0.04] text-white/45';
      });
      button.className = 'tag-pill bg-cubex-red/15 text-cubex-red';
      resetBrush(getSelectedSeries());
      drawAll();
    });
  });

  const ratioFromOverviewEvent = (event) => {
    if (!(overview instanceof HTMLCanvasElement)) return 0;
    const rect = overview.getBoundingClientRect();
    return clamp((event.clientX - rect.left) / Math.max(1, rect.width), 0, 1);
  };

  overview?.addEventListener('pointerdown', (event) => {
    const series = getSelectedSeries();
    if (!(overview instanceof HTMLCanvasElement) || !series || series.points.length < 2) return;

    const rect = overview.getBoundingClientRect();
    const ratio = ratioFromOverviewEvent(event);
    const edge = Math.max(0.012, 10 / Math.max(1, rect.width));
    const width = brush.end - brush.start;
    let mode = 'move';

    if (Math.abs(ratio - brush.start) <= edge) mode = 'resize-start';
    else if (Math.abs(ratio - brush.end) <= edge) mode = 'resize-end';
    else if (ratio < brush.start || ratio > brush.end) {
      mode = 'move';
      const nextStart = clamp(ratio - width / 2, 0, 1 - width);
      brush = { start: nextStart, end: nextStart + width };
      drawAll();
    }

    dragState = {
      mode,
      ratio,
      start: brush.start,
      end: brush.end,
    };
    overview.setPointerCapture(event.pointerId);
  });

  overview?.addEventListener('pointermove', (event) => {
    if (!dragState) return;
    const ratio = ratioFromOverviewEvent(event);
    const delta = ratio - dragState.ratio;
    const minWidth = 0.01;

    if (dragState.mode === 'resize-start') {
      brush.start = clamp(ratio, 0, brush.end - minWidth);
    } else if (dragState.mode === 'resize-end') {
      brush.end = clamp(ratio, brush.start + minWidth, 1);
    } else {
      const width = dragState.end - dragState.start;
      const start = clamp(dragState.start + delta, 0, 1 - width);
      brush = { start, end: start + width };
    }

    drawAll();
  });

  const stopOverviewDrag = (event) => {
    if (overview instanceof HTMLCanvasElement && dragState) {
      overview.releasePointerCapture?.(event.pointerId);
    }
    dragState = null;
  };

  overview?.addEventListener('pointerup', stopOverviewDrag);
  overview?.addEventListener('pointercancel', stopOverviewDrag);

  const loadHistory = async () => {
    if (!chartRoot) return;
    try {
      const src = chartRoot.getAttribute('data-history-src') || '/data/server-history.json';
      const seriesConfig = JSON.parse(seriesScript?.textContent || '[]');
      const res = await fetch(src);
      const data = await res.json();
      allSeries = seriesConfig.map((series) => {
        const rawPoints = data.servers?.[series.id]?.points || [];
        return {
          ...series,
          points: rawPoints
            .map(([at, players]) => [Date.parse(at), Number(players || 0)])
            .filter(([time, players]) => Number.isFinite(time) && Number.isFinite(players))
            .sort(([a], [b]) => a - b),
        };
      });
      if (!selectedId && allSeries[0]) selectedId = allSeries[0].id;
      resetBrush(getSelectedSeries());
      drawAll();
    } catch {
      setMeta('历史曲线载入失败');
    }
  };

  window.addEventListener('resize', drawAll);
  loadHistory();
</script>
