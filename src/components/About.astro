---
import { timeline } from '../data/timeline';
---

<section id="about" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-cubex-red text-sm font-semibold tracking-widest uppercase mb-3">About Us</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">我们的故事</h2>
      <p class="text-white/45 max-w-2xl mx-auto">
        从一个社区到多个服务器，从玩家到组织者，CubeX 的故事是关于热爱与探索。
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <div class="timeline-line"></div>

      <div class="space-y-16">
        {timeline.map((event, i) => (
          <div class={`relative flex flex-col md:flex-row items-center gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Content card -->
            <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:text-left md:pl-12'}`}>
              <div class="glass-card p-6 md:p-8">
                <div class={`tag-pill bg-cubex-red/15 text-cubex-red mb-3 ${i % 2 === 0 ? 'md:ml-auto' : ''}`}>
                  {event.year}
                </div>
                <h3 class="text-xl font-bold mb-3">{event.title}</h3>
                <p class="text-white/50 leading-relaxed text-sm">{event.description}</p>
              </div>
            </div>

            <!-- Center dot -->
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-3 h-3 bg-cubex-red border-3 border-cubex-dark z-10"></div>

            <!-- Spacer for the other side -->
            <div class="flex-1 hidden md:block"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
