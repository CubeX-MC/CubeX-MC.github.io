---
import { servers } from '../data/servers';

const statusConfig: Record<string, { label: string; color: string; bg: string }> = {
  online: { label: '在线', color: 'text-cubex-green', bg: 'bg-cubex-green/15' },
  offline: { label: '离线', color: 'text-white/35', bg: 'bg-white/5' },
  'in-development': { label: '开发中', color: 'text-cubex-blue', bg: 'bg-cubex-blue/15' },
};
---

<section id="servers" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-cubex-red">Servers</p>
        <h2 class="text-3xl font-bold md:text-4xl">服务器列表</h2>
      </div>
      <p class="max-w-xl text-sm leading-relaxed text-white/45 md:text-right">
        养老服、RPG、玩家自治实验服和社区成员独立开设的服务器。状态会在页面加载后自动刷新。
      </p>
    </div>

    <!-- Server cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {servers.map((server) => {
        const status = server.status ? statusConfig[server.status] : null;
        return (
          <div class="glass-card p-5 flex flex-col" data-server-card={server.ip || ''}>
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="text-lg font-bold">{server.name}</h3>
                  <p class="text-white/35 text-sm">{server.subtitle}</p>
                </div>
                {status && (
                  <span class={`tag-pill ${status.bg} ${status.color}`} data-status-tag>
                    {status.label}
                  </span>
                )}
              </div>

              <p class="text-white/50 text-sm leading-relaxed mb-3 flex-1">
                {server.description}
              </p>

              <!-- Dynamic MOTD -->
              {server.ip && (
                <div class="bg-white/[0.03] px-4 py-2 mb-3" data-motd style="display:none;">
                  <p class="text-white/60 text-xs leading-relaxed" data-motd-text></p>
                </div>
              )}

              {server.ip && (
                <div class="bg-white/[0.03] px-4 py-2 mb-3 flex items-center justify-between">
                  <code class="text-cubex-green text-sm font-mono">{server.ip}</code>
                  <div class="flex items-center gap-2">
                    <span class="text-white/20 text-xs" data-players style="display:none;"></span>
                    <button
                      class="text-white/35 hover:text-white transition-colors text-xs"
                      data-copy={server.ip}
                      title="复制 IP"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    </button>
                  </div>
                </div>
              )}

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {server.tags.map((tag) => (
                  <span class="tag-pill bg-white/[0.04] text-white/45">{tag}</span>
                ))}
              </div>

              <!-- Links -->
              {server.links && server.links.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-2 border-t border-white/5">
                  {server.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-xs text-cubex-red hover:text-cubex-accent transition-colors flex items-center gap-1"
                    >
                      {link.label}
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  ))}
                </div>
              )}

              <!-- Operators -->
              <div class="text-xs text-white/25 mt-3">
                现任服主: {server.operators.join(', ')}
              </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Copy IP
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (text) {
        try {
          await navigator.clipboard.writeText(text);
          btn.setAttribute('title', '已复制!');
          setTimeout(() => btn.setAttribute('title', '复制 IP'), 2000);
        } catch {}
      }
    });
  });

  // Fetch server status from mcsrvstat.us
  document.querySelectorAll('[data-server-card]').forEach(async card => {
    const ip = card.getAttribute('data-server-card');
    if (!ip) return;

    const statusTag = card.querySelector('[data-status-tag]');
    const motdContainer = card.querySelector('[data-motd]');
    const motdText = card.querySelector('[data-motd-text]');
    const playersEl = card.querySelector('[data-players]');

    try {
      const res = await fetch(`https://api.mcsrvstat.us/3/${ip}`);
      const data = await res.json();

      if (data.online) {
        if (statusTag) {
          statusTag.textContent = '在线';
          statusTag.className = 'tag-pill bg-cubex-green/15 text-cubex-green';
        }

        if (motdContainer && motdText) {
          const motd = data.motd?.clean?.join(' ') || data.motd?.clean?.[0] || '';
          if (motd) {
            motdText.textContent = motd;
            motdContainer.style.display = 'block';
          }
        }

        if (playersEl && data.players) {
          const online = data.players.online || 0;
          const max = data.players.max || 0;
          playersEl.textContent = `${online}/${max}`;
          playersEl.style.display = 'inline';
        }
      } else {
        if (statusTag) {
          statusTag.textContent = '离线';
          statusTag.className = 'tag-pill bg-white/5 text-white/35';
        }
      }
    } catch {
      // API failed, keep default status
    }
  });
</script>
