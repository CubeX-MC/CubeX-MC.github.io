---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CubeX · HyperCube — Minecraft Server Organization',
  description = 'CubeX / HyperCube 是一个 Minecraft 服务器组织，起源于 WolfX Commune 社区。我们探索不同的服务器模式，维护自己的插件生态。',
} = Astro.props;

const navItems = [
  { href: '/lookup', label: '查询' },
  { href: '/records', label: '纪录' },
  { href: '/servers', label: '服务器' },
  { href: '/#guestbook', label: '留言' },
  { href: '/chat', label: '聊天' },
  { href: '/community', label: '社区' },
  { href: '/plugins', label: '插件' },
  { href: '/members', label: '成员' },
  { href: '/about', label: '故事' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const navClass = (href: string) => {
  const hrefPath = href.split('#')[0].replace(/\/$/, '') || '/';
  const isActive = currentPath === hrefPath;
  return isActive
    ? 'text-white transition-colors'
    : 'text-white/50 hover:text-white transition-colors';
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/imgs/server-icon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+SC:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;500&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-grid min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-cubex-darker/80 backdrop-blur-xl">
      <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center group" aria-label="CubeX">
          <div class="inline-flex items-center justify-center" style="perspective: 200px;">
            <div class="nav-cube-spin" style="width:22px; height:22px; position:relative; transform-style:preserve-3d;">
              <div style="position:absolute; inset:0; transform:rotateY(0deg) translateZ(11px);">
                <img src="/imgs/server-icon.png" alt="" style="width:22px; height:22px; display:block;" />
              </div>
              <div style="position:absolute; inset:0; transform:rotateY(90deg) translateZ(11px);">
                <img src="/imgs/server-icon.png" alt="" style="width:22px; height:22px; display:block;" />
              </div>
              <div style="position:absolute; inset:0; transform:rotateY(180deg) translateZ(11px);">
                <img src="/imgs/server-icon.png" alt="" style="width:22px; height:22px; display:block;" />
              </div>
              <div style="position:absolute; inset:0; transform:rotateY(270deg) translateZ(11px);">
                <img src="/imgs/server-icon.png" alt="" style="width:22px; height:22px; display:block;" />
              </div>
            </div>
          </div>
        </a>
        <div class="hidden md:flex items-center gap-4 text-sm">
          {navItems.map((item) => (
            <a href={item.href} class={navClass(item.href)}>{item.label}</a>
          ))}
          <div class="w-px h-4 bg-white/8"></div>
          <a href="https://github.com/CubeX-MC" target="_blank" rel="noopener" class="text-white/50 hover:text-white transition-colors flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://modrinth.com/organization/cubexmc" target="_blank" rel="noopener" class="text-white/50 hover:text-white transition-colors flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 7.318l-2.928 11.288a.84.84 0 01-.812.628.84.84 0 01-.812-.628l-1.625-6.26-1.625 6.26a.84.84 0 01-.812.628.84.84 0 01-.812-.628L6.44 7.318h2.058L10.8 13.93l1.634-6.612h1.132l1.634 6.612 2.302-6.612h2.058z"/></svg>
            Modrinth
          </a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-white/50 hover:text-white transition-colors p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-cubex-darker/95 backdrop-blur-xl">
        <div class="px-6 py-4 flex flex-col gap-3 text-sm">
          {navItems.map((item) => (
            <a href={item.href} class={`${navClass(item.href)} py-1`}>{item.label}</a>
          ))}
          <div class="h-px bg-white/8 my-1"></div>
          <a href="https://github.com/CubeX-MC" target="_blank" rel="noopener" class="text-white/50 hover:text-white transition-colors py-1">GitHub</a>
          <a href="https://modrinth.com/organization/cubexmc" target="_blank" rel="noopener" class="text-white/50 hover:text-white transition-colors py-1">Modrinth</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-white/5 mt-32">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex flex-col md:flex-row justify-between items-start gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="font-bold text-sm">
                <span class="text-cubex-red">Cube</span>X
              </span>
            </div>
            <p class="text-white/30 text-sm max-w-xs">
              CubeX / HyperCube — 一个持续探索的 Minecraft 服务器组织。起源于 WolfX Commune 社区。
            </p>
          </div>
          <div class="flex gap-12 text-sm">
            <div>
              <h4 class="font-semibold text-white/70 mb-3 text-xs uppercase tracking-wider">链接</h4>
              <div class="flex flex-col gap-2">
                <a href="https://github.com/CubeX-MC" target="_blank" rel="noopener" class="text-white/35 hover:text-white/60 transition-colors">GitHub</a>
                <a href="https://modrinth.com/organization/cubexmc" target="_blank" rel="noopener" class="text-white/35 hover:text-white/60 transition-colors">Modrinth</a>
                <a href="https://cubexmc.org" class="text-white/35 hover:text-white/60 transition-colors">cubexmc.org</a>
              </div>
            </div>
            <div>
              <h4 class="font-semibold text-white/70 mb-3 text-xs uppercase tracking-wider">社区</h4>
              <div class="flex flex-col gap-2">
                <a href="https://discord.gg/7tJeSZPZgv" target="_blank" rel="noopener" class="text-white/35 hover:text-white/60 transition-colors">HyperCube Discord</a>
                <a href="https://t.me/cbxmc" target="_blank" rel="noopener" class="text-white/35 hover:text-white/60 transition-colors">Telegram</a>
                <a href="https://space.bilibili.com/3546921981446556" target="_blank" rel="noopener" class="text-white/35 hover:text-white/60 transition-colors">Bilibili</a>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t border-white/5 mt-8 mb-6"></div>
        <div class="flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-white/25">
          <p>&copy; 2024–2026 CubeX / HyperCube</p>
          <p>起源于 WolfX Commune，永不止步。</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menu?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
