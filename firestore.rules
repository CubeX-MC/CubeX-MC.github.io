rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /chat-messages/{msg} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['author', 'userId', 'name', 'content', 'timestamp']) &&
        request.resource.data.author in ['user', 'ai'] &&
        request.resource.data.userId is string &&
        request.resource.data.userId.size() > 0 &&
        request.resource.data.userId.size() <= 64 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 12 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 500 &&
        request.resource.data.timestamp == request.time;

      allow update, delete: if false;
    }
  }
}
